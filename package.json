{
  "name": "soc-assessment",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win portable",
    "build:linux": "vite build && electron-builder --linux AppImage",
    "preview": "vite preview",
    "test": "vitest run",
    "test:report": "vitest run --reporter=json --outputFile=tests/reports/results.json"
  },
  "build": {
    "appId": "com.soc.assessment",
    "productName": "SOC-Assessment",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "SOC-Assessment-${version}-win7-portable.exe"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-matrix": "^3.0.4",
    "dexie": "^4.4.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "electron-packager": "^15.5.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
